<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kb_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_subtitle"
            android:textColor="@color/text_dim"
            android:textSize="14sp" />

        <!-- Setup -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_setup"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="48dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_mic"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/mic_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/state_pending"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <Button
                android:id="@+id/mic_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_grant" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="48dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_enable"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/enable_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/state_pending"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <Button
                android:id="@+id/enable_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_enable" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="48dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_select"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/select_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/state_pending"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <Button
                android:id="@+id/select_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_select" />
        </LinearLayout>

        <!-- Overlay bubble -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_overlay"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="48dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_overlay"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/overlay_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/state_pending"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <Button
                android:id="@+id/overlay_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_overlay_enable" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/overlay_hint"
            android:textColor="@color/text_dim"
            android:textSize="13sp" />

        <Switch
            android:id="@+id/cloud_preferred_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="48dp"
            android:text="@string/cloud_preferred_switch"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <!-- Suppress lint: plain Switch matches the rest of this screen -->
        <Switch
            android:id="@+id/flow_polish_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minHeight="48dp"
            android:text="@string/flow_polish_switch"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/bubble_size" android:textColor="@color/text_primary" />
        <SeekBar android:id="@+id/bubble_size_seek" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="115" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/bubble_opacity" android:textColor="@color/text_primary" />
        <SeekBar android:id="@+id/bubble_opacity_seek" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" />
        <Switch android:id="@+id/bubble_shrink_switch" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/bubble_shrink" android:textColor="@color/text_primary" />
        <Switch android:id="@+id/local_recovery_switch" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/local_recovery" android:textColor="@color/text_primary" />

        <Switch
            android:id="@+id/local_refine_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minHeight="48dp"
            android:text="@string/local_refine_switch"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <!-- Personal dictionary -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_dictionary"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/dictionary_editor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_key"
            android:gravity="top|start"
            android:hint="@string/dictionary_hint"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minHeight="96dp"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_dim"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/dictionary_help"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <!-- Voice snippets -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_snippets"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/snippet_editor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_key"
            android:gravity="top|start"
            android:hint="@string/snippet_hint"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minHeight="96dp"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_dim"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/snippet_help"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_style"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/style_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton android:id="@+id/style_auto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/style_auto" android:textColor="@color/text_primary" />
            <RadioButton android:id="@+id/style_neutral" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/style_neutral" android:textColor="@color/text_primary" />
            <RadioButton android:id="@+id/style_formal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/style_formal" android:textColor="@color/text_primary" />
            <RadioButton android:id="@+id/style_casual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/style_casual" android:textColor="@color/text_primary" />
            <RadioButton android:id="@+id/style_concise" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/style_concise" android:textColor="@color/text_primary" />
        </RadioGroup>

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_language"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/language_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radio_system"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_system"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/radio_de"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_de"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/radio_en"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_en"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/radio_auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lang_auto"
                android:textColor="@color/text_primary" />
        </RadioGroup>

        <!-- Cloud opt-in -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_cloud"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/cloud_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/cloud_switch"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/cloud_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_dim"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/login_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_login"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/login_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/login_state_checking"
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <Button
                android:id="@+id/login_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_login" />
        </LinearLayout>

        <!-- Privacy -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/privacy_note"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
