<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded state while dictating: [cancel] [live text / status] [confirm]. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pill_root"
    android:layout_width="wrap_content"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_pill"
    android:elevation="8dp"
    android:paddingStart="6dp"
    android:paddingEnd="6dp">

    <ImageButton
        android:id="@+id/pill_cancel"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_close"
        android:padding="12dp"
        android:contentDescription="@string/overlay_cancel_desc" />

    <TextView
        android:id="@+id/pill_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:maxWidth="220dp"
        android:minWidth="80dp"
        android:maxLines="1"
        android:ellipsize="start"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:text="@string/status_listening" />

    <ImageButton
        android:id="@+id/pill_confirm"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_check"
        android:backgroundTint="@color/accent"
        android:padding="12dp"
        android:contentDescription="@string/overlay_confirm_desc" />
</LinearLayout>
