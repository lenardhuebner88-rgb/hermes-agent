<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTERNET is used ONLY by the explicit cloud opt-in path and the settings login WebView.
         The default on-device dictation path never opens a network connection. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Plan-F lesson (2026-07-10): Android's speech/WebRTC audio stack switches the audio mode
         (AudioManager.setMode) when opening the mic; without MODIFY_AUDIO_SETTINGS the capture
         init can fail even though the mic is free. Declared from day 1. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <!-- Package visibility (target API 30+): without this, resolving the platform's
         RecognitionService — and thus on-device availability checks — can fail. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.HermesDictate">

        <!-- The dictation keyboard itself. BIND_INPUT_METHOD restricts binding to the system. -->
        <service
            android:name=".DictateInputMethodService"
            android:exported="true"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <activity
            android:name=".SettingsActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Wispr-Flow-style overlay bubble: works over ANY app via BIND_ACCESSIBILITY_SERVICE.
             No SYSTEM_ALERT_WINDOW permission needed — TYPE_ACCESSIBILITY_OVERLAY is granted to
             a bound accessibility service. Enabled by the user in Android's Bedienungshilfen. -->
        <service
            android:name=".DictateOverlayService"
            android:exported="true"
            android:label="@string/overlay_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
